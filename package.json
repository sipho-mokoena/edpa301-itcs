{
  "name": "edpa301-itcs",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "fmt": "vp fmt",
    "build:packages": "vp run -r build --filter packages/*",
    "build:apps": "vp run -r build --filter apps/*",
    "build:tools": "vp run -r build --filter tools/*",
    "build": "vp run -r build",
    "test:packages": "vp run -r test --filter packages/*",
    "test:apps": "vp run -r test --filter apps/*",
    "test:tools": "vp run -r test --filter tools/*",
    "test": "vp run -r test"
  },
  "dependencies": {
    "vite-plus": "^0.1.19"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.0.0"
}
